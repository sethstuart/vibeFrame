# vibeFrame configuration. Copy to .env and adjust.

# Filesystem
VIBEFRAME_PHOTOS_DIR=/vibeFrame
VIBEFRAME_UPLOAD_SUBDIR=_uploads
VIBEFRAME_CACHE_DIR=/var/cache/vibeframe
VIBEFRAME_STATE_DIR=/var/lib/vibeframe
VIBEFRAME_RECURSIVE=true

# Display
VIBEFRAME_DRIVER=auto              # auto | mock
VIBEFRAME_ORIENTATION=270          # 0 | 90 | 180 | 270
VIBEFRAME_REFRESH_SECONDS=1800     # 30 minutes
VIBEFRAME_SELECTION_MODE=shuffle   # shuffle | sequential | favorites | recent

# Quiet hours (skip refreshes inside this window; manual "show now" overrides)
VIBEFRAME_QUIET_HOURS_ENABLED=true
VIBEFRAME_QUIET_START=22:00
VIBEFRAME_QUIET_END=07:00
VIBEFRAME_TZ=UTC

# Image processing
VIBEFRAME_DITHER=floyd-steinberg   # floyd-steinberg | atkinson | bayer | none
VIBEFRAME_CROP_MODE=smart          # smart | center | fit
VIBEFRAME_SATURATION=1.15
VIBEFRAME_CONTRAST=1.05

# Web UI
VIBEFRAME_WEB_HOST=0.0.0.0
VIBEFRAME_WEB_PORT=8080
VIBEFRAME_METRICS_REFRESH_SECONDS=10  # Metrics page auto-refresh interval
# VIBEFRAME_WEB_TOKEN=changeme     # uncomment to require token on write endpoints

# Logging
VIBEFRAME_LOG_LEVEL=INFO

# Cache size (bytes); LRU eviction kicks in above this.
VIBEFRAME_CACHE_MAX_BYTES=524288000  # 500 MB
